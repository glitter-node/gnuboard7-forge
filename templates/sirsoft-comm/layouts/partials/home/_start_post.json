{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "bg-white dark:bg-slate-800 rounded-xl p-4 shadow-md border border-slate-200 dark:border-slate-700"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex flex-col gap-3"
      },
      "responsive": {
        "desktop": {
          "props": {
            "className": "flex flex-row items-center justify-between gap-4"
          }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-1"
          },
          "children": [
            {
              "type": "basic",
              "name": "H2",
              "props": {
                "className": "text-lg font-semibold text-slate-900 dark:text-white"
              },
              "text": "$t:home.start_post_title"
            },
            {
              "type": "basic",
              "name": "P",
              "props": {
                "className": "text-sm text-slate-600 dark:text-slate-400"
              },
              "text": "$t:home.start_post_description"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "grid grid-cols-1 gap-2"
          },
          "responsive": {
            "tablet": {
              "props": {
                "className": "grid grid-cols-2 gap-2"
              }
            }
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "flex min-h-[84px] w-full items-center gap-3 rounded-lg border border-teal-200 bg-teal-50 px-4 py-3 text-left transition-colors hover:border-teal-300 hover:bg-teal-100 dark:border-teal-800 dark:bg-teal-950/30 dark:hover:border-teal-700 dark:hover:bg-teal-950/50 cursor-pointer"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "switch",
                  "params": {
                    "value": "{{_global.currentUser?.uuid ? 'authenticated' : 'guest'}}"
                  },
                  "cases": {
                    "authenticated": {
                      "handler": "navigate",
                      "params": {
                        "path": "/board/free/write"
                      }
                    },
                    "guest": {
                      "handler": "navigate",
                      "params": {
                        "path": "/login",
                        "query": {
                          "redirect": "/board/free/write"
                        }
                      }
                    }
                  }
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "messages-square",
                    "className": "h-5 w-5 shrink-0 text-teal-600 dark:text-teal-400"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "min-w-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "block text-sm font-semibold text-slate-900 dark:text-white"
                      },
                      "text": "$t:boards.free"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "mt-1 block text-xs text-slate-600 dark:text-slate-400"
                      },
                      "text": "$t:home.start_post_free_description"
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "flex min-h-[84px] w-full items-center gap-3 rounded-lg border border-sky-200 bg-sky-50 px-4 py-3 text-left transition-colors hover:border-sky-300 hover:bg-sky-100 dark:border-sky-800 dark:bg-sky-950/30 dark:hover:border-sky-700 dark:hover:bg-sky-950/50 cursor-pointer"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "switch",
                  "params": {
                    "value": "{{_global.currentUser?.uuid ? 'authenticated' : 'guest'}}"
                  },
                  "cases": {
                    "authenticated": {
                      "handler": "navigate",
                      "params": {
                        "path": "/board/qna/write"
                      }
                    },
                    "guest": {
                      "handler": "navigate",
                      "params": {
                        "path": "/login",
                        "query": {
                          "redirect": "/board/qna/write"
                        }
                      }
                    }
                  }
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "circle-help",
                    "className": "h-5 w-5 shrink-0 text-sky-600 dark:text-sky-400"
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "min-w-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "block text-sm font-semibold text-slate-900 dark:text-white"
                      },
                      "text": "$t:boards.qna"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "mt-1 block text-xs text-slate-600 dark:text-slate-400"
                      },
                      "text": "$t:home.start_post_qna_description"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
