{
  "version": "1.0.0",
  "layout_name": "home",
  "permissions": [],
  "extends": "_user_base",
  "meta": {
    "seo": {
      "enabled": true,
      "data_sources": [
        "stats",
        "recent_posts",
        "popular_boards"
      ],
      "priority": 1.0,
      "changefreq": "daily",
      "og": {
        "type": "website",
        "title": "$t:home.seo_title",
        "description": "$t:home.seo_description",
        "image": "/images/og-default.png"
      },
      "structured_data": {
        "@type": "WebSite",
        "name": "{{_global.site_name ?? ''}}",
        "url": "{{_global.site_url ?? ''}}"
      }
    }
  },
  "data_sources": [
    {
      "id": "stats",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/boards/stats",
      "method": "GET",
      "auto_fetch": true,
      "loading_strategy": "progressive",
      "fallback": {
        "data": {
          "users": 0,
          "posts": 0,
          "comments": 0,
          "boards": 0
        }
      }
    },
    {
      "id": "recent_posts",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/boards/posts/recent?limit=5",
      "method": "GET",
      "auto_fetch": true,
      "loading_strategy": "progressive",
      "fallback": {
        "data": []
      }
    },
    {
      "id": "popular_boards",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/boards/popular-boards?limit=4",
      "method": "GET",
      "auto_fetch": true,
      "loading_strategy": "progressive",
      "fallback": {
        "data": []
      }
    }
  ],
  "slots": {
    "content": [
      {
        "type": "layout",
        "name": "Container",
        "props": {
          "className": "py-6 px-4"
        },
        "responsive": {
          "tablet": {
            "props": {
              "className": "py-6 px-6"
            }
          },
          "desktop": {
            "props": {
              "className": "py-6 px-8"
            }
          }
        },
        "children": [
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "mb-4"
            },
            "children": [
              {
                "partial": "partials/home/_welcome_card.json"
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "mb-5"
            },
            "children": [
              {
                "partial": "partials/home/_notice_posts.json"
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "mb-5"
            },
            "children": [
              {
                "partial": "partials/home/_start_post.json"
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "grid grid-cols-1 gap-4 mb-5"
            },
            "responsive": {
              "desktop": {
                "props": {
                  "className": "grid grid-cols-2 gap-4 mb-5"
                }
              }
            },
            "children": [
              {
                "partial": "partials/home/_recent_posts.json"
              },
              {
                "partial": "partials/home/_popular_boards.json"
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "grid grid-cols-2 gap-3 mb-5"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "grid grid-cols-1 gap-3 mb-5"
                }
              }
            },
            "children": [
              {
                "partial": "partials/home/_stat_card_users.json"
              },
              {
                "partial": "partials/home/_stat_card_posts.json"
              },
              {
                "partial": "partials/home/_stat_card_comments.json"
              },
              {
                "partial": "partials/home/_stat_card_boards.json"
              }
            ]
          },
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "max-w-3xl"
            },
            "children": [
              {
                "partial": "partials/home/_community_guide.json"
              }
            ]
          }
        ]
      }
    ]
  }
}
