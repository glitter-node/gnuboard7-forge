{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "bg-slate-50 dark:bg-slate-800 rounded-xl p-4 shadow-md border border-slate-200/70 dark:border-slate-700 h-full flex flex-col transition-all hover:shadow-lg"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center justify-between mb-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-slate-900 dark:text-white flex items-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "clock",
                "className": "w-5 h-5 text-slate-500 dark:text-slate-400"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:home.recent_posts"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "text-sm text-teal-600 dark:text-teal-400 hover:underline flex items-center gap-1 cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/boards/popular"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.more"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "arrow-right",
                "className": "w-4 h-4"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{recent_posts.data && recent_posts.data.length > 0}}",
      "props": {
        "className": "space-y-2 mb-1"
      },
      "iteration": {
        "source": "{{recent_posts.data ?? []}}",
        "item_var": "post"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "block w-full text-left hover:bg-slate-50 dark:hover:bg-slate-700/50 rounded-lg py-2 transition-colors cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/{{post.board_slug}}/{{post.id}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center justify-between gap-2 text-xs"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-center gap-2 flex-1 min-w-0"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-teal-600 dark:text-teal-400 shrink-0"
                      },
                      "text": "{{post.board_name}}"
                    },
                    {
                      "type": "basic",
                      "name": "Icon",
                      "if": "{{post.is_secret}}",
                      "props": {
                        "name": "lock",
                        "className": "w-3.5 h-3.5 text-slate-400 dark:text-slate-500 shrink-0"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-sm font-medium text-slate-900 dark:text-white text-left line-clamp-1"
                      },
                      "text": "{{post.title}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post.is_new}}",
                      "props": {
                        "className": "px-1.5 py-0.5 text-xs bg-red-500 text-white rounded shrink-0"
                      },
                      "text": "$t:board.new_badge"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post.comment_count > 0}}",
                      "props": {
                        "className": "text-xs font-medium text-teal-500 dark:text-teal-400 shrink-0"
                      },
                      "text": "$t:home.comment_count_badge|count={{post.comment_count}}"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-xs text-slate-500 dark:text-slate-400 shrink-0",
                    "title": "{{post.created_at ?? ''}}"
                  },
                  "text": "{{post.created_at_formatted ?? ''}}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "if": "{{!recent_posts.data || recent_posts.data.length === 0}}",
      "props": {
        "className": "text-center py-7 px-4 text-slate-500 dark:text-slate-400 flex-grow flex flex-col items-center justify-center min-h-[180px] rounded-lg border border-dashed border-slate-200 dark:border-slate-700 bg-white/70 dark:bg-slate-900/30"
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": {
            "name": "message-square-plus",
            "className": "w-8 h-8 mx-auto mb-3 text-teal-500 dark:text-teal-400"
          }
        },
        {
          "type": "basic",
          "name": "H4",
          "props": {
            "className": "text-sm font-semibold text-slate-900 dark:text-white mb-1"
          },
          "text": "$t:home.recent_posts_empty_title"
        },
        {
          "type": "basic",
          "name": "P",
          "props": {
            "className": "text-sm max-w-sm"
          },
          "text": "$t:home.recent_posts_empty_description"
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "type": "button",
            "className": "mt-4 inline-flex items-center gap-1 text-sm font-medium text-teal-600 dark:text-teal-400 hover:underline cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/boards"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:home.empty_browse_boards"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "arrow-right",
                "className": "w-4 h-4"
              }
            }
          ]
        }
      ]
    }
  ]
}
