{
  "meta": {
    "is_partial": true
  },
  "type": "basic",
  "name": "Div",
  "if": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'notice';}).length > 0}}",
  "props": {
    "className": "bg-white dark:bg-slate-800 rounded-xl p-4 shadow-md border border-teal-200/80 dark:border-teal-800 h-full"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex items-center justify-between mb-3"
      },
      "children": [
        {
          "type": "basic",
          "name": "H3",
          "props": {
            "className": "text-lg font-semibold text-slate-900 dark:text-white flex items-center gap-2"
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "megaphone",
                "className": "w-5 h-5 text-teal-600 dark:text-teal-400"
              }
            },
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:home.notice_posts"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "text-sm text-teal-600 dark:text-teal-400 hover:underline flex items-center gap-1 cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/notice"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "text": "$t:common.more"
            },
            {
              "type": "basic",
              "name": "Icon",
              "props": {
                "name": "arrow-right",
                "className": "w-4 h-4"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "space-y-2"
      },
      "iteration": {
        "source": "{{(recent_posts?.data ?? []).filter(function(post){return (post?.board_slug ?? '') === 'notice';}).slice(0, 2)}}",
        "item_var": "post"
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": {
            "className": "block w-full text-left rounded-lg border border-slate-100 dark:border-slate-700 bg-slate-50/80 dark:bg-slate-900/30 px-3 py-2.5 hover:border-teal-200 dark:hover:border-teal-700 transition-colors cursor-pointer"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/notice/{{post?.id ?? ''}}"
              }
            }
          ],
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-2 min-w-0"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-xs font-semibold text-teal-600 dark:text-teal-400 shrink-0"
                  },
                  "text": "$t:boards.notice"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": {
                    "className": "text-sm font-medium text-slate-900 dark:text-white line-clamp-1"
                  },
                  "text": "{{post?.title ?? ''}}"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{post?.is_new ?? false}}",
                  "props": {
                    "className": "px-1.5 py-0.5 text-xs bg-red-500 text-white rounded shrink-0"
                  },
                  "text": "$t:board.new_badge"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "mt-1 block text-xs text-slate-500 dark:text-slate-400",
                "title": "{{post?.created_at ?? ''}}"
              },
              "text": "{{post?.created_at_formatted ?? ''}}"
            }
          ]
        }
      ]
    }
  ]
}
